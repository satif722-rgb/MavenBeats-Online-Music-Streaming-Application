@model DemoMusicMVC.Models.Playlist

@{
    ViewData["Title"] = "Delete Playlist";
}

<h2>Delete Playlist</h2>
<h3>Are you sure you want to delete this playlist?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">Playlist Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Created</dt>
        <dd class="col-sm-10">@Model.CreatedDate.ToLocalTime().ToString("MMM dd, yyyy")</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="PlaylistId" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
