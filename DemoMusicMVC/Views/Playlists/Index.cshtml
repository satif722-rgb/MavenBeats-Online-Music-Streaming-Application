@model IEnumerable<DemoMusicMVC.Models.Playlist>

@{
    ViewData["Title"] = "My Playlists";
}

<h2>My Playlists</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Create New Playlist
    </a>
</p>

@if (!Model.Any())
{
    <p class="text-muted">You have no playlists yet. Create one to get started!</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3">
        @foreach (var playlist in Model)
        {
            <div class="col mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@playlist.Name</h5>
                        <p class="card-text text-muted small">
                            Created: @playlist.CreatedDate.ToLocalTime().ToString("MMM dd, yyyy")
                        </p>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@playlist.PlaylistId" class="btn btn-primary btn-sm">
                            <i class="fas fa-list"></i> View
                        </a>
                        <form asp-action="Delete" asp-route-id="@playlist.PlaylistId" method="get" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
